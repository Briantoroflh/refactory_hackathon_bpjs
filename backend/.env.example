# Database Configuration
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sprintflow
DATABASE_ECHO=False

# Connection Pooling
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Application Settings
DEBUG=False
API_TITLE=SprintFlow API
API_VERSION=0.1.0

# GitLab Integration Configuration
GITLAB_API_BASE_URL=https://gitlab.com
GITLAB_SYNC_INTERVAL_MINUTES=15
GITLAB_ENABLE_AUTO_SYNC=True

# Token Encryption (for storing GitLab API keys)
TOKEN_ENCRYPTION_KEY=your-32-character-encryption-key-here
